<UserControl x:Class="PicShow.Views.PreviewHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PicShow.Models"
             SizeChanged="UserControl_SizeChanged">
    <Grid x:Name="Root"
          ClipToBounds="True"
          PreviewMouseWheel="Root_PreviewMouseWheel">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Background" Value="{StaticResource CheckerboardBrush}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding TransparencyBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Value="{x:Static models:TransparencyBackground.Light}">
                        <Setter Property="Background" Value="#FFFFFFFF" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding TransparencyBackground, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 Value="{x:Static models:TransparencyBackground.Dark}">
                        <Setter Property="Background" Value="#FF202327" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Canvas x:Name="ImageCanvas"
                ClipToBounds="True">
            <Image x:Name="PreviewImage"
                   Stretch="Fill"
                   SnapsToDevicePixels="True"
                   UseLayoutRounding="True"
                   Cursor="SizeAll"
                   MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                   MouseMove="PreviewImage_MouseMove"
                   MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp"
                   MouseLeave="PreviewImage_MouseLeave" />
        </Canvas>

        <Border x:Name="MessagePanel"
                Margin="24"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Background="#CC181A1F"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="560">
            <StackPanel>
                <TextBlock x:Name="MessageTitle"
                           Text="请选择或拖入图片/PDF"
                           FontSize="22"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="MessageDetail"
                           Text="当前基础版支持 JPG、PNG、BMP、TIFF、ICO 的静态预览。GIF/SVG/PSD/PDF 将在后续步骤接入专用渲染器。"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

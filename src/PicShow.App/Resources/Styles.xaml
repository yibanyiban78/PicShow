<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF181A1F" />
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#FF22252B" />
    <SolidColorBrush x:Key="FloatingToolbarBrush" Color="#DD22252B" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FF202329" />
    <SolidColorBrush x:Key="SplitterBrush" Color="#FF30343C" />
    <SolidColorBrush x:Key="BorderBrush" Color="#FF383D46" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF3F5F7" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FFB8C0CC" />

    <LinearGradientBrush x:Key="WelcomeBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF101820" Offset="0" />
        <GradientStop Color="#FF1B2430" Offset="0.55" />
        <GradientStop Color="#FF101319" Offset="1" />
    </LinearGradientBrush>

    <DrawingBrush x:Key="CheckerboardBrush"
                  TileMode="Tile"
                  Viewport="0,0,24,24"
                  ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#FFE5E7EB">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,24,24" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#FFC9CED6">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,12,12" />
                            <RectangleGeometry Rect="12,12,12,12" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <Style TargetType="Window">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="MinWidth" Value="64" />
    </Style>

    <Style x:Key="ViewerToolbarButton" TargetType="Button">
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="MinWidth" Value="58" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="#0030343C" />
        <Setter Property="BorderBrush" Value="#0030343C" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#333F4652" />
                            <Setter Property="BorderBrush" Value="#554D5664" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#664D5664" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WindowControlButton" TargetType="Button">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="#99000000" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#CC000000" />
                            <Setter Property="BorderBrush" Value="#66FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#F0000000" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ImageEditToolbar" TargetType="Border">
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Background" Value="#99000000" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="ImageEditToolbarButton" TargetType="Button">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="34" />
        <Setter Property="MinWidth" Value="38" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="#00111111" />
        <Setter Property="BorderBrush" Value="#00111111" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="17"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#443F4652" />
                            <Setter Property="BorderBrush" Value="#55FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#774D5664" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ImageEditToolbarSeparator" TargetType="Separator">
        <Setter Property="Margin" Value="8,6" />
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="#44FFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Width="{TemplateBinding Width}"
                            Margin="{TemplateBinding Margin}"
                            Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WelcomeOpenButton" TargetType="Button">
        <Setter Property="MinWidth" Value="132" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#FF101820" />
        <Setter Property="Background" Value="#FFE9F6FF" />
        <Setter Property="BorderBrush" Value="#FFFFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="20"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              Direction="270"
                                              ShadowDepth="7"
                                              Opacity="0.32"
                                              Color="#FF000000" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFFFFFFF" />
                            <Setter Property="BorderBrush" Value="#FF9FD6F6" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#FFD2ECFB" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WelcomeHintText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Regular" />
        <Setter Property="Foreground" Value="#FF7FE7FF" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="WelcomeMetaText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#B8D8E7F0" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="WelcomeAuthorText" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#A8D8E7F0" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="None" />
    </Style>

    <Style x:Key="ToolbarSeparator" TargetType="Separator">
        <Setter Property="Margin" Value="8,5" />
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{StaticResource BorderBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Width="{TemplateBinding Width}"
                            Margin="{TemplateBinding Margin}"
                            Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="6,3" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource SidebarBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="PanelTitleText" TargetType="TextBlock">
        <Setter Property="Margin" Value="14,12,14,8" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</ResourceDictionary>
